{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "VoxNovel 桌面端默认权限集",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "dialog:default",
    "notification:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPLOCALDATA/**" }, { "path": "D:/voxnovel/test-assets/**" }, { "path": "D:/voxnovel/recordings/**" }]
    }
  ]
}
