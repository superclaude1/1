<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".StoryBrainApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StoryBrain"
        android:requestLegacyExternalStorage="true"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name=".ui.home.ImportActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 接收外部 txt 文件直接打开 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:scheme="content" />
                <data android:scheme="file" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.reader.ReaderActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <activity
            android:name=".ui.graph.GraphActivity"
            android:exported="false"
            android:label="@string/title_plot_graph" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings" />

        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="false"
            android:label="全书搜索"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.character.CharacterDetailActivity"
            android:exported="false"
            android:label="角色详情" />

        <activity
            android:name=".ui.home.BookDetailActivity"
            android:exported="false"
            android:label="书籍详情" />

        <activity
            android:name=".ui.character.CharacterChatActivity"
            android:exported="false"
            android:label="与角色聊天"
            android:windowSoftInputMode="adjustResize" />

        <!-- 异步流水线 Worker 通过 WorkManager 自动调度 -->
    </application>
</manifest>
