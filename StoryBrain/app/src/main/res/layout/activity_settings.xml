<?xml version="1.0" encoding="utf-8"?>
<!-- settings activity layout: Apple iOS Settings grouped layout style -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/wechat_bg">

    <!-- 顶部导航栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/wechat_title_bar"
        app:titleTextColor="@color/wechat_title_text"
        app:titleTextAppearance="@style/StoryBrain.ToolbarTitle"
        android:elevation="0dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/wechat_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <!-- SECTION 1: LLM CONFIG -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="大语言模型 (LLM)"
                android:textColor="@color/wechat_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/StoryBrain.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Provider Selector -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="提供商"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <RadioGroup
                            android:id="@+id/radioGroupProvider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/radioDeepseek"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="16dp"
                                android:checked="true"
                                android:buttonTint="@color/wechat_green"
                                android:text="DeepSeek"
                                android:textSize="13sp" />

                            <RadioButton
                                android:id="@+id/radioGemini"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="@color/wechat_green"
                                android:text="Gemini"
                                android:textSize="13sp" />
                        </RadioGroup>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginBottom="12dp" />

                    <!-- API Key Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="API Key"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="@null"
                            android:hint="请输入 API Key"
                            android:textColorHint="@color/wechat_hint"
                            android:textColor="@color/wechat_title_text"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginBottom="12dp" />

                    <!-- Model Name Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="模型名称"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editModel"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:textColor="@color/wechat_title_text"
                            android:maxLines="1"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/btnCheckModels"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="检测列表"
                            android:textColor="@color/apple_blue"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginBottom="12dp" />

                    <!-- Base URL Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="接口地址"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editBaseUrl"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="@null"
                            android:textColor="@color/wechat_title_text"
                            android:inputType="textUri"
                            android:maxLines="1"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- LLM Controls -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnTest"
                            style="@style/StoryBrain.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="测试连接"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnSave"
                            style="@style/StoryBrain.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="保存配置"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="@color/wechat_hint" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: READING PREFERENCES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="内容清洗偏好"
                android:textColor="@color/wechat_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/StoryBrain.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchAiClean"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI 智能深度去广告"
                        android:textStyle="bold"
                        android:textColor="@color/wechat_title_text"
                        android:textSize="14sp"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/wechat_green" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="12sp"
                        android:textColor="@color/wechat_hint"
                        android:lineSpacingMultiplier="1.2"
                        android:text="启用后会在分析前调用大模型过滤小说网站防盗水印、推广、求票等噪音（每章多消耗一次 Token）。本地自带的基础正则表达式清洗依然有效且免费。" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 3: TTS SETTINGS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="声音与朗读设置"
                android:textColor="@color/wechat_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/StoryBrain.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Engine Picker -->
                    <RadioGroup
                        android:id="@+id/rgTtsEngine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbTtsSystem"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/wechat_green"
                            android:text="系统本地 TTS（纯离线，支持多音调）"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="13sp" />

                        <RadioButton
                            android:id="@+id/rbTtsEdge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/wechat_green"
                            android:text="微软 Edge-TTS（高逼真，智能分配音色）"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                        <RadioButton
                            android:id="@+id/rbTtsServer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/wechat_green"
                            android:text="电脑端大模型配音（连接 PC 管理器）"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />
                    </RadioGroup>

                    <!-- Server Config (Conditional Visibility) -->
                    <LinearLayout
                        android:id="@+id/layoutTtsServerConfig"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="@color/apple_separator"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="85dp"
                                android:layout_height="wrap_content"
                                android:text="服务器地址"
                                android:textColor="@color/wechat_title_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />

                            <EditText
                                android:id="@+id/editTtsServer"
                                android:layout_width="match_parent"
                                android:layout_height="38dp"
                                android:background="@null"
                                android:hint="http://192.168.1.xxx:18083"
                                android:textColorHint="@color/wechat_hint"
                                android:textColor="@color/wechat_title_text"
                                android:inputType="textUri"
                                android:maxLines="1"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <!-- SeekBar Speech Interval -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textTtsInterval"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="句间停顿: 0 毫秒"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />

                        <SeekBar
                            android:id="@+id/sbTtsInterval"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:max="2000"
                            android:progress="0"
                            android:splitTrack="false"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnTtsSave"
                        style="@style/StoryBrain.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:text="保存语音配置"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/ttsStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="@color/wechat_hint" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 4: WEBDAV BACKUP -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="数据云备份 (WebDAV)"
                android:textColor="@color/wechat_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/StoryBrain.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Server Url -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="服务器地址"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editWebDavUrl"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="@null"
                            android:hint="坚果云等 dav 接口 url"
                            android:textColorHint="@color/wechat_hint"
                            android:textColor="@color/wechat_title_text"
                            android:inputType="textUri"
                            android:maxLines="1"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginBottom="12dp" />

                    <!-- Username -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="用户名"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editWebDavUser"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="@null"
                            android:textColor="@color/wechat_title_text"
                            android:maxLines="1"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginBottom="12dp" />

                    <!-- Password -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="应用密码"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editWebDavPass"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="@null"
                            android:hint="应用授权独立密码"
                            android:textColorHint="@color/wechat_hint"
                            android:textColor="@color/wechat_title_text"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginBottom="12dp" />

                    <!-- Remote Path -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="85dp"
                            android:layout_height="wrap_content"
                            android:text="备份目录"
                            android:textColor="@color/wechat_title_text"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/editWebDavPath"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="@null"
                            android:textColor="@color/wechat_title_text"
                            android:maxLines="1"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- WebDAV Actions Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <Button
                            android:id="@+id/btnWebDavTest"
                            style="@style/StoryBrain.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="测试连接"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnWebDavSave"
                            style="@style/StoryBrain.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="保存配置"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- WebDAV Actions Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnBackup"
                            style="@style/StoryBrain.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="📤 备份至云端"
                            android:textSize="13sp"
                            app:backgroundTint="@color/apple_blue" />

                        <Button
                            android:id="@+id/btnRestore"
                            style="@style/StoryBrain.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="📥 从云端恢复"
                            android:textSize="13sp"
                            app:backgroundTint="@color/apple_blue" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/webdavStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="@color/wechat_hint" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
