<?xml version="1.0" encoding="utf-8"?>
<!-- book detail layout: Apple HIG Card-grouped design style -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/wechat_bg">

    <!-- 顶部导航栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/wechat_title_bar"
        app:titleTextColor="@color/wechat_title_text"
        app:titleTextAppearance="@style/StoryBrain.ToolbarTitle"
        android:elevation="0dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/wechat_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <!-- 书籍主卡片：书名、章节、最近阅读时间 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/StoryBrain.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <!-- 书籍大封面 -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="72dp"
                            android:layout_height="96dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0.5dp"
                            app:strokeColor="@color/apple_separator"
                            app:cardBackgroundColor="@color/apple_fill_secondary">
                            
                            <TextView
                                android:id="@+id/bookAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:textSize="28sp"
                                android:fontFamily="serif"
                                android:textStyle="bold"
                                android:textColor="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- 右侧书目详情 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvBookTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                android:textColor="@color/wechat_title_text" />

                            <TextView
                                android:id="@+id/tvChaptersInfo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textSize="13sp"
                                android:textColor="@color/wechat_hint" />

                            <TextView
                                android:id="@+id/tvReadProgress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:textSize="13sp"
                                android:textColor="@color/wechat_hint" />

                            <TextView
                                android:id="@+id/tvLastReadTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:textSize="12sp"
                                android:textColor="@color/wechat_hint" />

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/apple_separator"
                        android:layout_marginBottom="16dp" />

                    <!-- 操作按钮行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRead"
                            style="@style/StoryBrain.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="继续阅读"
                            android:textSize="13sp"
                            app:icon="@android:drawable/ic_menu_slideshow"
                            app:iconTint="@android:color/white"
                            app:iconSize="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGraph"
                            style="@style/StoryBrain.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="剧情图谱"
                            android:textSize="13sp"
                            app:icon="@android:drawable/ic_dialog_map"
                            app:iconTint="@color/wechat_green"
                            app:iconSize="16dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 角色列表标题 -->
            <TextView
                android:id="@+id/tvCharacterHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="书中角色"
                android:textColor="@color/wechat_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03" />

            <!-- 角色列表容器 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/characterCardContainer"
                style="@style/StoryBrain.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCharacters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvEmptyCharacters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="24dp"
                        android:text="暂无已分析出的角色，请在阅读时等待后台自动分析。"
                        android:textSize="13sp"
                        android:textColor="@color/wechat_hint"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
